#!/bin/bash

# Define a distinct folder name to avoid conflict with the script file
BASE_DIR="$HOME/Chunker_Data"
ZIP_DIR="$BASE_DIR/Zip"
UNZIP_DIR="$BASE_DIR/Unzip"

# Create the folders
mkdir -p "$ZIP_DIR" "$UNZIP_DIR"

echo "--- Chunker ---"
echo "1. Slice"
echo "2. Rejoin"
read -p "Choose (1/2): " CHOICE

if [ "$CHOICE" == "1" ]; then
    read -p "Drag file/folder here to SLICE: " SRC_PATH
    # Clean the path from drag-and-drop quotes/spaces
    SRC_PATH=$(echo "$SRC_PATH" | sed "s/'//g; s/\"//g; s/ $//")
    
    read -p "Chunk size in MB (e.g., 10 or 3800): " MB_SIZE
    
    # Get the parent directory and the actual file name
    DIR_NAME=$(dirname "$SRC_PATH")
    NAME=$(basename "$SRC_PATH")
    FINAL_DEST="$ZIP_DIR/$NAME-chunks"
    mkdir -p "$FINAL_DEST"

    echo "Slicing $NAME into ${MB_SIZE}MB chunks..."
    
    # -C jumps into the parent dir so 'tar' doesn't save the full Mac path
    tar -czf - -C "$DIR_NAME" "$NAME" | split -b "${MB_SIZE}m" - "$FINAL_DEST/chunk_"
    
    echo "Success! Chunks are in: $ZIP_DIR/$NAME-chunks"

elif [ "$CHOICE" == "2" ]; then
    read -p "Drag CHUNK FOLDER here to REJOIN: " FOLDER_PATH
    # Clean the path
    FOLDER_PATH=$(echo "$FOLDER_PATH" | sed "s/'//g; s/\"//g; s/ $//")

    # Verify if it's a real folder
    if [ ! -d "$FOLDER_PATH" ]; then
        echo "Error: That folder doesn't exist!"
        exit 1
    fi

    echo "Rejoining chunks from $(basename "$FOLDER_PATH")..."
    
    # Joins the chunks and extracts directly into the Unzip folder
    cat "$FOLDER_PATH"/chunk_* | tar -xzf - -C "$UNZIP_DIR"
    
    echo "Done! Check your files in: $UNZIP_DIR"
fi



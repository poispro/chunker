#!/bin/bash

# Define a distinct folder name to avoid conflict with the script file
BASE_DIR="$HOME/ChunkerData"
ZIP_DIR="$BASE_DIR/Zip"
UNZIP_DIR="$BASE_DIR/Unzip"

# Create the folder (this will work now because it's not named 'chunker')
mkdir -p "$ZIP_DIR" "$UNZIP_DIR"

echo "--- Chunker ---"
echo "1. Slice"
echo "2. Rejoin"
read -p "Choose (1/2): " CHOICE

if [ "$CHOICE" == "1" ]; then
    read -p "Drag file/folder here: " SRC_PATH
    SRC_PATH=$(echo "$SRC_PATH" | sed "s/'//g; s/\"//g; s/ $//")
    
    read -p "Chunk size in MB (e.g., 10 or 3800): " MB_SIZE
    BYTE_SIZE=$((MB_SIZE * 1000 * 1000))
    
    DIR_NAME=$(dirname "$SRC_PATH")
    NAME=$(basename "$SRC_PATH")
    FINAL_DEST="$ZIP_DIR/$NAME-chunks"
    mkdir -p "$FINAL_DEST"

    echo "Slicing $NAME into ${MB_SIZE}MB chunks..."
    tar -czf - -C "$DIR_NAME" "$NAME" | split -b "$BYTE_SIZE" - "$FINAL_DEST/chunk_"
    
    echo "Success! Chunks are in: ~/ChunkerData/Zip/"

elif [ "$CHOICE" == "2" ]; then
    echo "Available chunks in ChunkerData:"
    echo "1) [Manual path entry]"
    
    declare -a FOLDERS
    INDEX=2
    # Look in the new directory name
    for dir in "$ZIP_DIR"/*; do
        if [ -d "$dir" ]; then
            FOLDERS[$INDEX]="$dir"
            echo "$INDEX) $(basename "$dir")"
            ((INDEX++))
        fi
    done
    
    read -p "Select a number: " UNZIP_CHOICE
    
    if [ "$UNZIP_CHOICE" == "1" ]; then
        read -p "Drag CHUNK FOLDER here: " FOLDER_PATH
        FOLDER_PATH=$(echo "$FOLDER_PATH" | sed "s/'//g; s/\"//g; s/ $//")
    else
        FOLDER_PATH="${FOLDERS[$UNZIP_CHOICE]}"
    fi
    
    FOLDER_NAME=$(basename "$FOLDER_PATH")
    RESTORE_NAME="${FOLDER_NAME%-chunks}"
    
    echo "Rejoining to ~/ChunkerData/Unzip..."
    cat "$FOLDER_PATH"/chunk_* | tar -xzf - -C "$UNZIP_DIR"
    echo "Done!"
fi
